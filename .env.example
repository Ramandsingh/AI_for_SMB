# Copy this to .env for local dev, or set these as GitHub Secrets for CI/CD.
# The deploy workflow writes these automatically from GitHub Secrets.

DB_ROOT_PASSWORD=change_me_root
DB_USER=ai_dashboard_user
DB_PASSWORD=change_me_password
DB_NAME=ai_dashboard_db

# LAN IP shown in QR code on /lab/upload — set to your server's fixed LAN address
# so the QR code always points to the right host from any phone on the same Wi-Fi.
# Example: LAN_IP=192.168.68.199
LAN_IP=
